# ============================================
# AsistenteVirtual - Environment Configuration
# ============================================
# Copy to .env and adjust values for your environment
#   cp .env.example .env
# ============================================

# Database
POSTGRES_DB=asistente_virtual
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform123
DATABASE_URL=postgres://platform:platform123@postgres:5432/asistente_virtual

# Backend
PORT=3000
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRATION_HOURS=24
FRONTEND_URL=http://localhost

# Asterisk AMI
ASTERISK_HOST=asterisk
ASTERISK_PORT=5038
ASTERISK_USER=admin
ASTERISK_PASSWORD=admin
ASTERISK_ENV=docker

# SMTP
SMTP_HOST=mailhog
SMTP_PORT=1025

# SFTP (for Asterisk config upload)
FTP_HOST=
FTP_USER=
FTP_PWD=

# LDAP
LDAP_HOST=
LDAP_BIND_DN=
LDAP_BASE_DN=
LDAP_BASE_USER=
LDAP_TIMEOUT=5000
