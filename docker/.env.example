# ============================================
# AsistenteVirtual - Environment Configuration
# ============================================
# Copy to .env and adjust values for your environment
#   cp .env.example .env
# ============================================

# Database
POSTGRES_DB=asistente_virtual
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform123

# Backend
PORT=3000
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRATION_HOURS=24
FRONTEND_URL=https://localhost

# Asterisk AMI
# Use host.docker.internal or 172.17.0.1 (Asterisk runs in host network mode)
ASTERISK_HOST=172.17.0.1
ASTERISK_PORT=5038
ASTERISK_USER=admin
ASTERISK_PASSWORD=admin
ASTERISK_ENV=docker

# SMTP
SMTP_HOST=localhost
SMTP_PORT=25

# SFTP (for Asterisk config upload)
FTP_HOST=
FTP_USER=
FTP_PWD=

# LDAP
LDAP_HOST=
LDAP_BIND_DN=
LDAP_BASE_DN=
LDAP_BASE_USER=
LDAP_TIMEOUT=5000

# Logging
RUST_LOG=info

# SSL (path to directory with server.crt and server.key)
SSL_CERT_DIR=./ssl
